// prisma/schema.prisma
// SQLite-compatible: enums → String, Json → String

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Admin-only account (the site owner). No public signup flow is linked from
// the UI — this exists purely to gate /admin.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

// audience values: STUDENT | EARLY_CAREER | FOUNDER | GENERAL (stored as String for SQLite)
// difficulty values: Easy | Medium | Hard
// tags: comma-separated free text, e.g. "remote,paid,ai"
// source values: user-provided | researched
model Opportunity {
  id            String    @id @default(cuid())
  title         String
  description   String
  url           String
  org           String?
  audience      String
  eligibility   String    @default("")
  prepResources String    @default("")
  difficulty    String    @default("Medium")
  tags          String    @default("")
  location      String?
  region        String    @default("") // North America | South America | Europe | Africa | Asia | Oceania | Remote / Global | "" (unknown)
  country       String    @default("") // best-effort from location text, e.g. "India" — "" if not confidently known
  compType      String?
  viewCount     Int       @default(0)
  verified      Boolean   @default(false)
  featured      Boolean   @default(false)
  featuredUntil DateTime? // set only for paid "Featured" upsells — the hourly scrape cron unsets `featured` once this passes
  source        String    @default("user-provided")
  sourceUrl     String?
  addedAt       DateTime  @default(now())
  deletedAt     DateTime?

  @@index([audience, addedAt])
  @@index([verified])
  @@index([featured])
  @@index([region])
}

// plan/subscriptionStatus are only ever written by a verified payment-provider
// webhook (lib/billing) — never trust a client request to set them directly.
model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())

  plan                   String    @default("free") // "free" | "paid"
  paymentProvider        String?                     // "razorpay" — more can be added later (e.g. "paypal")
  paymentSubscriptionId  String?   @unique
  subscriptionStatus     String?                     // provider's own status string, e.g. "active" | "halted" | "cancelled"
  currentPeriodEnd       DateTime?

  // Referral loop: this subscriber's own shareable code, and whose code (if
  // any) they arrived with. Both plain strings, no FK — same loose-coupling
  // style as the rest of this schema (see OpportunitySubmission.opportunityId).
  referralCode String? @unique
  referredBy   String?

  @@index([plan])
  @@index([referredBy])
}

// A visitor's bookmarked opportunity. Keyed to the same lightweight
// Subscriber row + cookie session that already exists for free/paid
// browsing — no new account system, per lib/subscriberSession.ts's existing
// low-stakes tradeoff (this data is no more sensitive than early access).
model SavedOpportunity {
  id            String   @id @default(cuid())
  subscriberId  String
  opportunityId String
  savedAt       DateTime @default(now())

  @@unique([subscriberId, opportunityId])
  @@index([subscriberId])
}

// A browser's Web Push subscription — tied to a Subscriber so "matching"
// (lib/push.ts) can compare newly added opportunities against the
// audiences of what that subscriber has saved. lastNotifiedAt throttles
// sends to at most once per window rather than every hourly scrape pass.
model PushSubscription {
  id            String    @id @default(cuid())
  subscriberId  String
  endpoint      String    @unique
  p256dh        String
  auth          String
  createdAt     DateTime  @default(now())
  lastNotifiedAt DateTime?

  @@index([subscriberId])
}

// A paid public submission ("enlist your opportunity"). Nothing here ever
// becomes a live Opportunity on its own — the Razorpay webhook is the only
// thing allowed to flip status to "paid" once payment is actually confirmed,
// and even then the resulting Opportunity is created unverified so it still
// goes through the same human review queue as everything else.
model OpportunitySubmission {
  id               String    @id @default(cuid())
  razorpayOrderId  String    @unique
  status           String    @default("pending") // pending | paid | rejected
  submitterEmail   String
  payload          String    // JSON string of the submitted opportunity fields
  opportunityId    String?   // set once the paid Opportunity row is created
  createdAt        DateTime  @default(now())

  @@index([status])
}

// A manually-booked sponsor line for the daily Telegram/Discord digest —
// "Today's picks, brought to you by X." Deliberately has no payment
// integration: there's no self-serve checkout for this, and none is
// planned until the distribution channels have enough of an audience that
// an advertiser would actually pay for a slot. Whoever runs OppIDX invoices
// a sponsor directly and creates one row here; the digest cron picks up
// whichever row (if any) covers today's date automatically.
model SponsoredSlot {
  id          String   @id @default(cuid())
  sponsorName String
  sponsorUrl  String
  tagline     String   // short line shown alongside the sponsor name, e.g. "Hiring backend engineers"
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())

  @@index([startDate, endDate])
}

// One row per native scraper pass (see lib/scraper). `details` is a JSON
// string keyed by source name: { fetched, added, error }.
model ScrapeRun {
  id         String   @id @default(cuid())
  startedAt  DateTime
  finishedAt DateTime
  added      Int      @default(0)
  details    String   @default("{}")

  @@index([startedAt])
}
