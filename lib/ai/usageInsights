import OpenAI from "openai";

const openai = new OpenAI({
  apiKey: process.env.OPENAI_API_KEY,
});

export interface UsageSession {
  startTime: number;
  endTime: number;
  platforms: string[];
  scrollTime: number;
  brainScoreBefore: number;
  brainScoreAfter: number;
}

export interface DailyUsage {
  date: string;
  totalScrollTime: number;
  sessions: UsageSession[];
  platformBreakdown: Record<string, number>;
  peakUsageHour: number;
  brainScoreAvg: number;
}

export interface UsageInsight {
  pattern: string;
  trigger: string;
  impact: "positive" | "negative" | "neutral";
  suggestion: string;
}

export async function generateInsights(usage: DailyUsage[]): Promise<UsageInsight[]> {
  const usageSummary = usage.map(day => ({
    date: day.date,
    totalMinutes: Math.round(day.totalScrollTime / 60),
    platforms: day.platformBreakdown,
    peakHour: day.peakUsageHour,
    avgBrainScore: day.brainScoreAvg,
  }));

  const res = await openai.chat.completions.create({
    model: "gpt-4o-mini",
    messages: [
      {
        role: "system",
        content: `You are a digital wellness coach. Analyze usage patterns and identify triggers for unhealthy social media use. Be specific, actionable, and supportive - not preachy.`
      },
      {
        role: "user",
        content: `Analyze this week's social media usage and identify patterns:

${JSON.stringify(usageSummary, null, 2)}

Return JSON array of insights:
[{
  "pattern": "<what you noticed>",
  "trigger": "<likely cause>",
  "impact": "<positive|negative|neutral>",
  "suggestion": "<specific actionable advice>"
}]

Give 3-5 insights. Be specific about times, platforms, and behaviors.`
      }
    ],
    response_format: { type: "json_object" }
  });

  const result = JSON.parse(res.choices[0].message.content || "{}");
  return result.insights || [];
}

export function trackSession(
  existing: DailyUsage | null,
  session: UsageSession
): DailyUsage {
  const today = new Date().toISOString().split("T")[0];
  
  if (!existing || existing.date !== today) {
    existing = {
      date: today,
      totalScrollTime: 0,
      sessions: [],
      platformBreakdown: {},
      peakUsageHour: 0,
      brainScoreAvg: 100,
    };
  }

  existing.sessions.push(session);
  existing.totalScrollTime += session.scrollTime;

  // Update platform breakdown
  session.platforms.forEach(platform => {
    existing!.platformBreakdown[platform] = 
      (existing!.platformBreakdown[platform] || 0) + session.scrollTime;
  });

  // Calculate peak hour
  const hourCounts: Record<number, number> = {};
  existing.sessions.forEach(s => {
    const hour = new Date(s.startTime).getHours();
    hourCounts[hour] = (hourCounts[hour] || 0) + s.scrollTime;
  });
  existing.peakUsageHour = Number(
    Object.entries(hourCounts).sort((a, b) => b[1] - a[1])[0]?.[0] || 0
  );

  // Calculate avg brain score
  const scores = existing.sessions.map(s => s.brainScoreAfter);
  existing.brainScoreAvg = Math.round(
    scores.reduce((a, b) => a + b, 0) / scores.length
  );

  return existing;
}

export function formatTime(minutes: number): string {
  if (minutes < 60) return `${minutes}m`;
  const hours = Math.floor(minutes / 60);
  const mins = minutes % 60;
  return mins > 0 ? `${hours}h ${mins}m` : `${hours}h`;
}

export function getUsageLevel(minutesPerDay: number): {
  level: "healthy" | "moderate" | "excessive";
  color: string;
  message: string;
} {
  if (minutesPerDay <= 60) {
    return { level: "healthy", color: "#22c55e", message: "Great balance!" };
  } else if (minutesPerDay <= 180) {
    return { level: "moderate", color: "#eab308", message: "Could be better" };
  } else {
    return { level: "excessive", color: "#ef4444", message: "Time to cut back" };
  }
}