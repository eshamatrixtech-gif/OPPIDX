// prisma/schema.prisma
// SQLite-compatible: enums → String, Json → String

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Admin-only account (the site owner). No public signup flow is linked from
// the UI — this exists purely to gate /admin.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

// audience values: STUDENT | EARLY_CAREER | FOUNDER | GENERAL (stored as String for SQLite)
// difficulty values: Easy | Medium | Hard
// tags: comma-separated free text, e.g. "remote,paid,ai"
// source values: user-provided | researched
model Opportunity {
  id            String    @id @default(cuid())
  title         String
  description   String
  url           String
  org           String?
  audience      String
  eligibility   String    @default("")
  prepResources String    @default("")
  difficulty    String    @default("Medium")
  tags          String    @default("")
  location      String?
  region        String    @default("") // North America | South America | Europe | Africa | Asia | Oceania | Remote / Global | "" (unknown)
  country       String    @default("") // best-effort from location text, e.g. "India" — "" if not confidently known
  compType      String?
  viewCount     Int       @default(0)
  verified      Boolean   @default(false)
  featured      Boolean   @default(false)
  source        String    @default("user-provided")
  sourceUrl     String?
  addedAt       DateTime  @default(now())
  deletedAt     DateTime?

  @@index([audience, addedAt])
  @@index([verified])
  @@index([featured])
  @@index([region])
}

// plan/subscriptionStatus are only ever written by a verified payment-provider
// webhook (lib/billing) — never trust a client request to set them directly.
model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())

  plan                   String    @default("free") // "free" | "paid"
  paymentProvider        String?                     // "razorpay" — more can be added later (e.g. "paypal")
  paymentSubscriptionId  String?   @unique
  subscriptionStatus     String?                     // provider's own status string, e.g. "active" | "halted" | "cancelled"
  currentPeriodEnd       DateTime?

  @@index([plan])
}

// A paid public submission ("enlist your opportunity"). Nothing here ever
// becomes a live Opportunity on its own — the Razorpay webhook is the only
// thing allowed to flip status to "paid" once payment is actually confirmed,
// and even then the resulting Opportunity is created unverified so it still
// goes through the same human review queue as everything else.
model OpportunitySubmission {
  id               String    @id @default(cuid())
  razorpayOrderId  String    @unique
  status           String    @default("pending") // pending | paid | rejected
  submitterEmail   String
  payload          String    // JSON string of the submitted opportunity fields
  opportunityId    String?   // set once the paid Opportunity row is created
  createdAt        DateTime  @default(now())

  @@index([status])
}

// One row per native scraper pass (see lib/scraper). `details` is a JSON
// string keyed by source name: { fetched, added, error }.
model ScrapeRun {
  id         String   @id @default(cuid())
  startedAt  DateTime
  finishedAt DateTime
  added      Int      @default(0)
  details    String   @default("{}")

  @@index([startedAt])
}
